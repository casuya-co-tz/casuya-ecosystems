{
  "name": "casuya-math",
  "version": "1.0.0",
  "description": "Math, science equation, and graph rendering for the Casuya educational platform",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@casuya/common": "workspace:*",
    "katex": "^0.17.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "license": "MIT"
}
